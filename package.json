{
  "name": "honeymate",
  "version": "5.1.0",
  "description": "Dead simple loading animations",
  "keywords": [
    "animations",
    "coordinator",
    "js"
  ],
  "bugs": {
    "url": "https://github.com/mishamyrt/honeymate/issues"
  },
  "license": "MIT",
  "author": "Mikhael Khrustik",
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md",
    "style.css"
  ],
  "main": "dist/honeymate.js",
  "scripts": {
