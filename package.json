    "test": "pnpm run test:unit",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown": "^1.0.2",
    "vitest": "^4.1.7"
